# Copy to .env for local overrides, or set these in your host's dashboard.

# Password to protect the app. If unset, the app is open (no login).
APP_PASSWORD=

# Turso (cloud SQLite). If unset, a local SQLite file (server/local.db) is used.
# Get these from the Turso dashboard or CLI:
#   turso db show <name> --url
#   turso db tokens create <name>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
